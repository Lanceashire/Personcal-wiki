---
import Cover from '@components/ui/cover/Cover.astro';
import WikiSidebar from '@components/wiki/WikiSidebar.astro';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import { getPublicWikiEntries, sitePath } from '@lib/wiki';

const entries = await getPublicWikiEntries();
const tags = new Map<string, number>();
for (const entry of entries) for (const tag of entry.data.tags) tags.set(tag, (tags.get(tag) ?? 0) + 1);
const base = import.meta.env.BASE_URL;
---

<Layout title="标签索引 · Personal Wiki" description="通过标签横向探索知识条目。">
  <TwoColumnLayout>
    <Cover slot="cover" title="标签索引" />
    <WikiSidebar slot="sider" entries={entries} />
    <main class="wiki-shell bg-gradient-start shadow-box p-5 md:p-4" data-pagefind-ignore>
      <p class="wiki-kicker">Tag Index</p><h1 class="wiki-title text-5xl">标签索引</h1>
      <p class="wiki-lede">标签用于跨领域发现具有共同方法、用途或技术背景的条目。</p>
      <div class="wiki-chip-row mt-8">
        {[...tags].sort(([a], [b]) => a.localeCompare(b, 'zh-CN')).map(([tag, count]) => (
          <a class="wiki-chip" href={sitePath(`wiki-tags/${encodeURIComponent(tag)}/`, base)}>#{tag} · {count}</a>
        ))}
      </div>
    </main>
  </TwoColumnLayout>
</Layout>
